{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/scrape-reviews.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/scrape-reviews",
      "schedule": "0 6 * * *"
    }
  ]
}
